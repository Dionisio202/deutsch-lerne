---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const allPosts = await getCollection('blog');

type CourseStructure = Record<string, Record<string, typeof allPosts>>;
const groupedStructure: CourseStructure = {};

allPosts.forEach((post) => {
  const level    = post.data.level    || 'Otros';
  const sublevel = post.data.sublevel || 'General';
  if (!groupedStructure[level])           groupedStructure[level] = {};
  if (!groupedStructure[level][sublevel]) groupedStructure[level][sublevel] = [];
  groupedStructure[level][sublevel].push(post);
});

const sortedLevels = Object.keys(groupedStructure).sort();
---

<!doctype html>
<html lang="es">
  <head>
    <BaseHead title={`Estructura del Curso - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="wrapper">

      <header class="page-header">
        <h1>Deutsch Struktur</h1>
      </header>

      <div class="course-tree">
        {sortedLevels.map((level) => {
          const sublevels = Object.keys(groupedStructure[level]).sort();
          const totalTopics = Object.values(groupedStructure[level]).reduce((s, arr) => s + arr.length, 0);

          return (
            <div class="tree-level">

              {/* Etiqueta del nivel */}
              <div class="tree-level__label">
                <span class="level-badge">{level}</span>
                <span class="level-count">{totalTopics} temas</span>
              </div>

              {/* Llave + subniveles */}
              <div class="tree-level__body">
                <div class="brace-wrap">
                  <span class="brace" aria-hidden="true">{"{"}</span>
                </div>

                <div class="sublevels">
                  {sublevels.map((sublevel) => {
                    const posts = groupedStructure[level][sublevel].sort((a, b) => {
                      const oa = a.data.order ?? 999;
                      const ob = b.data.order ?? 999;
                      if (oa !== ob) return oa - ob;
                      return a.data.pubDate.valueOf() - b.data.pubDate.valueOf();
                    });

                    return (
                      <div class="tree-sublevel">

                        {/* Etiqueta del subnivel */}
                        <div class="tree-sublevel__label">
                          <span class="sublevel-badge">{sublevel}</span>
                          <span class="sublevel-count">{posts.length} temas</span>
                        </div>

                        {/* Segunda llave + lista de temas */}
                        <div class="tree-sublevel__body">
                          <div class="brace-wrap brace-wrap--sm">
                            <span class="brace brace--sm" aria-hidden="true">{"{"}</span>
                          </div>

                          <ol class="topic-list">
                            {posts.map((post, i) => (
                              <li class="topic-item">
                                <a href={`/blog/${post.id}/`} class="topic-link">
                                  <span class="topic-num">{post.data.order ?? i + 1}</span>
                                  <span class="topic-title">{post.data.title}</span>
                                  {post.data.category && (
                                    <span class="topic-cat">{post.data.category}</span>
                                  )}
                                </a>
                              </li>
                            ))}
                          </ol>
                        </div>

                      </div>
                    );
                  })}
                </div>
              </div>

            </div>
          );
        })}
      </div>

    </main>
    <Footer />
  </body>
</html>

<style>
  /* ── Base ── */
  .wrapper {
    max-width: 960px;
    margin: 0 auto;
    padding: 2.5rem 1.25rem 5rem;
  }

  /* ── Encabezado ── */
  .page-header  { margin-bottom: 3rem; }
  .eyebrow      { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.09em; text-transform: uppercase; color: var(--accent); margin: 0 0 0.35rem; }
  .page-header h1 { font-size: 2.25rem; margin: 0; color: rgb(var(--black)); }

  /* ── Árbol principal ── */
  .course-tree {
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
  }

  /* ── NIVEL (A1, A2…) ── */
  .tree-level {
    display: flex;
    align-items: flex-start;
    gap: 0;
  }

  .tree-level__label {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding-top: 6px;
    min-width: 56px;
    flex-shrink: 0;
  }

  .level-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    font-weight: 800;
    color: #fff;
    background: var(--accent);
    padding: 4px 10px;
    border-radius: 5px;
    letter-spacing: 0.04em;
  }

  .level-count {
    font-size: 0.65rem;
    color: var(--gray, #888);
    white-space: nowrap;
  }

  /* ── Llave grande ── */
  .tree-level__body {
    display: flex;
    align-items: stretch;
    flex: 1;
    min-width: 0;
  }

  .brace-wrap {
    display: flex;
    align-items: center;
    padding: 0 4px;
    flex-shrink: 0;
  }

  .brace {
    font-size: 5rem;
    line-height: 1;
    color: var(--accent);
    font-weight: 100;
    opacity: 0.5;
    /* Escalamos la llave según la altura del contenido */
    display: block;
    transform: scaleY(var(--brace-scale, 1));
    transform-origin: center;
    user-select: none;
  }

  /* ── Subniveles dentro del nivel ── */
  .sublevels {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    flex: 1;
    min-width: 0;
    padding: 4px 0;
  }

  /* ── SUBNIVEL (A1.1, A1.2…) ── */
  .tree-sublevel {
    display: flex;
    align-items: flex-start;
    gap: 0;
  }

  .tree-sublevel__label {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    padding-top: 4px;
    min-width: 52px;
    flex-shrink: 0;
  }

  .sublevel-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.68rem;
    font-weight: 700;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 25%, transparent);
    padding: 3px 7px;
    border-radius: 4px;
    white-space: nowrap;
  }

  .sublevel-count {
    font-size: 0.6rem;
    color: var(--gray, #888);
    white-space: nowrap;
  }

  /* ── Llave pequeña ── */
  .tree-sublevel__body {
    display: flex;
    align-items: stretch;
    flex: 1;
    min-width: 0;
  }

  .brace-wrap--sm { padding: 0 2px; }

  .brace--sm {
    font-size: 2.5rem;
    line-height: 1;
    color: var(--accent);
    font-weight: 100;
    opacity: 0.35;
    display: block;
    transform: scaleY(var(--brace-scale, 1));
    transform-origin: center;
    user-select: none;
  }

  /* ── Lista de temas ── */
  .topic-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    flex: 1;
    min-width: 0;
    border: 1px solid rgb(var(--gray-light, 220 220 220));
    border-radius: 8px;
    overflow: hidden;
  }

  .topic-item + .topic-item {
    border-top: 1px solid rgb(var(--gray-light, 220 220 220));
  }

  .topic-link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 14px;
    text-decoration: none;
    color: rgb(var(--black));
    transition: background 0.15s, color 0.15s;
  }
  .topic-link:hover {
    background: color-mix(in srgb, var(--accent) 6%, transparent);
    color: var(--accent);
    text-decoration: none;
  }

  .topic-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.68rem;
    font-weight: 700;
    color: var(--accent);
    opacity: 0.4;
    min-width: 18px;
    text-align: right;
    flex-shrink: 0;
    transition: opacity 0.15s;
  }
  .topic-link:hover .topic-num { opacity: 1; }

  .topic-title {
    flex: 1;
    font-size: 0.875rem;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .topic-cat {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 2px 7px;
    background: rgb(var(--gray-light, 220 220 220));
    border-radius: 20px;
    color: rgb(var(--gray, 100 100 100));
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    /* En móvil colapsamos la llave y ponemos todo en columna */
    .tree-level,
    .tree-sublevel {
      flex-direction: column;
      gap: 0.5rem;
    }

    .tree-level__label,
    .tree-sublevel__label {
      flex-direction: row;
      align-items: center;
      gap: 8px;
      padding-top: 0;
      min-width: unset;
    }

    .tree-level__body,
    .tree-sublevel__body {
      padding-left: 12px;
      border-left: 2px solid color-mix(in srgb, var(--accent) 30%, transparent);
    }

    .brace-wrap,
    .brace-wrap--sm { display: none; }

    .topic-cat { display: none; }
  }
</style>
